spring.application.name=market-backend

# Supabase PostgreSQL — Transaction Mode (puerto 6543, no usar 5432 en producción)
spring.datasource.url=${DB_URL:jdbc:postgresql://YOUR_PROJECT.pooler.supabase.com:6543/postgres?sslmode=require}
spring.datasource.username=${DB_USERNAME:postgres.YOUR_PROJECT_REF}
spring.datasource.password=${DB_PASSWORD:}
spring.datasource.driver-class-name=org.postgresql.Driver

# HikariCP — máximo 5 conexiones por instancia JVM (pooler Supavisor suele limitar a 15)
spring.datasource.hikari.maximum-pool-size=5
spring.datasource.hikari.minimum-idle=1
spring.datasource.hikari.connection-timeout=20000
spring.datasource.hikari.idle-timeout=300000
spring.datasource.hikari.max-lifetime=600000
spring.datasource.hikari.pool-name=nubix-market-pool
spring.datasource.hikari.data-source-properties.prepareThreshold=0

# JPA / Hibernate
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=${SHOW_SQL:false}
spring.jpa.open-in-view=false

# JWT
jwt.secret=${JWT_SECRET:NubixMarketClaveSecretaMuyLargaYSegura2026}
jwt.expiration-ms=${JWT_EXPIRATION_MS:86400000}

# CORS (orígenes separados por coma)
cors.allowed-origins=${CORS_ORIGINS:http://localhost:5173}

# URL pública del API (imágenes dinámicas en correos)
app.public-base-url=${API_PUBLIC_URL:http://localhost:8080}

# Email SMTP
spring.mail.host=${MAIL_HOST:smtp.gmail.com}
spring.mail.port=${MAIL_PORT:587}
spring.mail.username=${MAIL_USERNAME:}
spring.mail.password=${MAIL_PASSWORD:}
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true
spring.mail.properties.mail.smtp.starttls.required=true
spring.mail.properties.mail.smtp.ssl.trust=${MAIL_HOST:smtp.gmail.com}
spring.mail.properties.mail.from=${MAIL_FROM:}

# Google Maps / Places Autocomplete (restringir por HTTP referrer en Google Cloud)
google.maps.api-key=${GOOGLE_MAPS_API_KEY:TU_GOOGLE_MAPS_API_KEY_AQUI}

# Consulta DNI / RUC (apisperu.com — solo desde backend)
# URL base sin barra final: https://dniruc.apisperu.com/api/v1
# Petición: {URL_BASE}/dni/{numero}?token={TOKEN}
dni.ruc.api.url=${DNI_RUC_API_URL:}
dni.ruc.api.token=${DNI_RUC_API_TOKEN:}
